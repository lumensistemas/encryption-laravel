{
    "name": "lumensistemas/encryption-laravel",
    "description": "Sodium-based encryption, decryption, and blind indexing for Laravel applications.",
    "keywords": [
        "lumensistemas",
        "encryption-laravel",
        "encryption",
        "sodium",
        "blind-indexing",
        "laravel"
    ],
    "homepage": "https://github.com/lumensistemas/encryption-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Lucas Vasconcelos",
            "email": "lucasvscn@pm.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-sodium": "*",
        "ext-mbstring": "*",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "LumenSistemas\\Encrypt\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LumenSistemas\\Encrypt\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyze": "phpstan analyse --memory-limit=512M",
        "analyse": "phpstan analyse --memory-limit=512M",
        "lint": ["rector process --memory-limit=512M", "pint"],
        "test": "pest --bail",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:arch": "pest --testsuite=Arch",
        "test:unit": "pest --testsuite=Unit",
        "test:feature": "pest --testsuite=Feature",
        "test:coverage": "pest --coverage --min=90",
        "test:lint": ["rector process --dry-run --clear-cache --memory-limit=512M", "pint --test"],
        "test:all": ["@test:lint", "@analyze", "@test:type-coverage", "@test:coverage"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LumenSistemas\\Encrypt\\EncryptionServiceProvider"
            ],
            "aliases": {
                "Encryption": "LumenSistemas\\Encrypt\\Facades\\Encryption"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
